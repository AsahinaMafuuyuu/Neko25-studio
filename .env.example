# Public browser env. Only use the Supabase anon key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase admin access. Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 media storage. The public base URL should point at the R2 public/custom domain.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
# 当用户开启 2FA 时，你的数据库一般会保存用户的 TOTP secret。
# 在项目根目录或者任意终端执行：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=

# App origin used by Trigger.dev tasks to resolve relative media URLs.
# Development: http://localhost:3000
# Production: https://neko25-studio.vercel.app
APP_BASE_URL=http://localhost:3000

# Development-only page auth bypass for local UI review tools such as Playwright.
# Set NEXT_PUBLIC_DEV_AUTH_BYPASS=false when you want to test the real login wall locally.
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
NEXT_PUBLIC_DEV_AUTH_EMAIL=dev-preview@kravix.local
NEXT_PUBLIC_DEV_AUTH_NAME=Development Preview
NEXT_PUBLIC_DEV_AUTH_AVATAR_URL=

# Trigger.dev
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=

# Provider secrets
SCRIPT_GENERATOR_API_URL=https://api.aisz.mom/v1/chat/completions
SCRIPT_GENERATOR_API_KEY=
SCRIPT_GENERATOR_MODEL=

IMAGE_MAKER_API_URL=
IMAGE_MAKER_API_KEY=
IMAGE_MAKER_MODEL=
IMAGE_MAKER_PROVIDER=agnes
IMAGE_MAKER_TIMEOUT_MS=120000
IMAGE_MAKER_DESKTOP_SIZE=1024x576
IMAGE_MAKER_MOBILE_SIZE=576x1024

REPLICATE_API_TOKEN=
REPLICATE_QWEN_TTS_MODEL=qwen/qwen3-tts
REPLICATE_QWEN_TTS_SPEAKER=Aiden
REPLICATE_WHISPERX_MODEL=
REPLICATE_POLL_TIMEOUT_MS=600000

DEEPGRAM_API_KEY=

AGNES_API_KEY=
AGNES_BROLL_API_KEY=

PIXABAY_API_KEY=

OPENROUTER_API_KEY=

VIDEO_GENERATOR_API_URL=https://apihub.agnes-ai.com/v1/videos
VIDEO_GENERATOR_MODEL=
VIDEO_GENERATOR_CHANNEL1_API_KEY=
VIDEO_GENERATOR_CHANNEL2_API_KEY=
VIDEO_GENERATOR_CHANNEL3_API_KEY=
VIDEO_GENERATOR_CHANNEL4_API_KEY=

# Webhooks
DOMOAI_WEBHOOK_SECRET=

# Optional ffmpeg override. ffmpeg-static is used when these are unset.
FFMPEG_BIN=
FFMPEG_PATH=
